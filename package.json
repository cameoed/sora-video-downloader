{
  "name": "sora-video-downloader",
  "version": "1.0.0",
  "private": true,
  "description": "Desktop Sora Video Downloader for macOS and Windows using Electron.",
  "author": "topher",
  "main": "desktop/main.js",
  "scripts": {
    "prepare:icons": "node desktop/scripts/prepare-icons.js",
    "prepare:release": "node desktop/scripts/prepare-release.js",
    "start:app": "node desktop/scripts/prepare-icons.js && electron .",
    "dist": "node desktop/scripts/prepare-release.js && CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --publish never",
    "dist:mac": "node desktop/scripts/prepare-release.js mac && CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --mac dmg --publish never",
    "dist:win": "node desktop/scripts/prepare-release.js win && electron-builder --win nsis --x64 --publish never"
  },
  "build": {
    "appId": "com.sora.video.downloader",
    "productName": "Sora Video Downloader",
    "asar": true,
    "directories": {
      "output": "release"
    },
    "extraResources": [
      {
        "from": "desktop/build-resources/ffmpeg",
        "to": "ffmpeg",
        "filter": [
          "**/*"
        ]
      }
    ],
    "files": [
      "desktop/**/*",
      "music/**/*",
      "icons/topher.webp",
      "!desktop/scripts/__pycache__{,/**/*}",
      "!desktop/scripts/prepare-ffmpeg.js",
      "!desktop/scripts/prepare-icons.js",
      "!desktop/scripts/prepare-release.js",
      "!desktop/build-resources/ffmpeg{,/**/*}",
      "uv-backup-logic.js",
      "README.md",
      "LICENSE"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "desktop/build-resources/icon.icns",
      "artifactName": "${productName}-${version}-${arch}.${ext}",
      "target": [
        "dmg"
      ]
    },
    "win": {
      "icon": "desktop/build-resources/icon.ico",
      "artifactName": "${productName}-${version}-${arch}.${ext}",
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": "always",
      "createStartMenuShortcut": true,
      "shortcutName": "Sora Video Downloader"
    }
  },
  "dependencies": {
    "playwright": "^1.52.0"
  },
  "devDependencies": {
    "electron": "^35.1.4",
    "electron-builder": "^24.13.3"
  }
}
